{
  "expo": {
    "name": "Rinse",
    "slug": "rinse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "rinse",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Rinse needs access to your photo library to help you clean and organize it. No photos are ever uploaded.",
        "NSPhotoLibraryAddUsageDescription": "Rinse needs this permission to save organized photos."
      }
    },
    "android": {
      "package": "com.muneer320.rinse",
      "adaptiveIcon": {
        "backgroundColor": "#0D0D0D",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image",
      "expo-splash-screen",
      [
        "expo-media-library",
        {
          "photosPermission": "Rinse needs access to your photos to help you clean your gallery. All processing is on-device.",
          "saveToGallery": false
        }
      ]
    ],
    "experiments": {
      "tsrPaths": true
    }
  }
}
